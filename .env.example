# sifresi DEGIL, "App Password" kullanilmali:
# 1) Gmail hesabinda 2 adimli dogrulamayi ac
# 2) https://myaccount.google.com/apppasswords adresinden "Mail" icin
#    16 haneli bir uygulama sifresi olustur
# 3) O sifreyi asagiya yapistir (boşluksuz)
MAIL_USERNAME=aykengur@gmail.com
MAIL_APP_PASSWORD=16-haneli-app-password
MAIL_SENDER_NAME=Big Bang Basketball
