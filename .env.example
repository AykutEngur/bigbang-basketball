# Bu dosyayi .env olarak kopyala ve kendi bilgilerinle doldur.
# .env dosyasi asla git'e commit edilmemeli (.gitignore'a eklendi).

# --- Flask ---
SECRET_KEY=buraya-uzun-rastgele-bir-anahtar-yaz

# --- MySQL ---
DB_HOST=localhost
